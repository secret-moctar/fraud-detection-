# =============================================================================
#  Project configuration
#  All knobs of the simulation and processing live here. docker-compose.yml
#  injects these values into the relevant containers. Change a value and run
#  `docker compose up -d --build` to apply it.
# =============================================================================

# ---- Kafka -------------------------------------------------------------------
KAFKA_TOPIC=transactions

# ---- Population (Section 4.1 of the statement) -------------------------------
# Full spec is N=100000 Bank X clients and M=200000 external users.
# These are cheap to keep at full scale (a few MB of numpy arrays).
POP_BANK_X=100000
POP_EXTERNAL=200000

# ---- Throughput --------------------------------------------------------------
# Target transactions per second for the live stream. The generator rescales
# the natural per-user probabilities to hit this number. Raise to 1000+ to
# demonstrate peak-hour load; lower it for a gentle demo on a small laptop.
TARGET_TPS=1000

# ---- Historical backfill -----------------------------------------------------
# Synthetic transactions sent once at startup, spread over the last N days, so
# the 7d / 3w / 3m sliding windows already contain data. Set BACKFILL_TX=0 to
# disable.
BACKFILL_TX=30000
BACKFILL_DAYS=90

# ---- Fraud injection (Section 4.4 "abnormal patterns for testing") -----------
# Every second the generator throws a coin: with probability FRAUD_RATE one
# random user becomes a "compromised account" for that second and emits a
# burst of FRAUD_BURST_SIZE high-value transactions to many random receivers
# (amount ~ FRAUD_AMOUNT_MULT * normal spending). This is exactly the pattern
# the dashboard's fraud rules are tuned to detect.
#
#   FRAUD_RATE=0.0     no fraud injected (default)
#   FRAUD_RATE=0.05    one fraud burst every ~20 seconds  (mild)
#   FRAUD_RATE=0.2     one fraud burst every ~5 seconds   (very visible demo)
FRAUD_RATE=0.2
FRAUD_BURST_SIZE=20
FRAUD_AMOUNT_MULT=10.0

# ---- Misc --------------------------------------------------------------------
# Random seed -> reproducible population and stream.
SEED=42

# How often the Spark processor recomputes the metrics.
TRIGGER_INTERVAL=5 seconds

# ---- Spark CPU allocation ----------------------------------------------------
# Two levels of "cores":
#
#   SPARK_WORKER_CORES    -> cores each Spark worker OFFERS to the cluster.
#                            (3 workers * SPARK_WORKER_CORES = total available)
#   SPARK_EXECUTOR_CORES  -> cores each executor of the app USES on a worker.
#   SPARK_CORES_MAX       -> total cores the app is allowed to grab across the
#                            whole cluster (1 executor per worker by default).
#
# Default values give a gentle demo: cluster has 6 cores available, the
# processor uses 3 (1 per worker), 3 cores stay free for the rest of the
# laptop. To run at full speed, set SPARK_CORES_MAX=6 (and optionally
# SPARK_EXECUTOR_CORES=2).
SPARK_WORKER_CORES=4
SPARK_EXECUTOR_CORES=3
SPARK_CORES_MAX=20

# ---- Multi-laptop (LAN) setup ------------------------------------------------
# Single-laptop demo: leave HOST_IP=localhost (default).
# Multi-laptop demo : set HOST_IP to the MAIN laptop's LAN IP, e.g.
#   HOST_IP=192.168.1.42
# That value is broadcast by Kafka as the EXTERNAL listener, so worker laptops
# on the same network can reach it. See docs/multi-laptop.md.
HOST_IP=10.34.12.85
